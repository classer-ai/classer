{
  "name": "classer-ai",
  "version": "0.0.1",
  "description": "Low-cost, fast AI classification API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "classification",
    "nlp",
    "machine-learning",
    "text-classification",
    "llm"
  ],
  "author": "Classer.ai",
  "license": "MIT",
  "homepage": "https://classer.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/classer-ai/classer-js"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
