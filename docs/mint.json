{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Classer",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5",
    "anchors": {
      "from": "#6366f1",
      "to": "#8b5cf6"
    }
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://classer.ai/dashboard"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://classer.ai/api-keys"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/classer-ai"
    },
    {
      "name": "Community",
      "icon": "discord",
      "url": "https://discord.gg/classer"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": ["introduction", "quickstart", "authentication"]
    },
    {
      "group": "SDKs",
      "pages": ["sdks/python", "sdks/typescript"]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/overview",
        "api-reference/classify",
        "api-reference/tag",
        "api-reference/match",
        "api-reference/score"
      ]
    }
  ],
  "footerSocials": {
    "twitter": "https://twitter.com/classerai",
    "github": "https://github.com/classer-ai"
  },
  "api": {
    "baseUrl": "https://api.classer.ai",
    "auth": {
      "method": "bearer"
    }
  }
}
